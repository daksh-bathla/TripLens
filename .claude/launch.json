{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web"],
      "port": 3000
    },
    {
      "name": "Backend (Express + MongoDB)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nodemon", "server.mjs"],
