{
  "name": "triplens",
  "version": "1.0.0",
  "description": "TripLens AI travel planner",
  "main": "server.mjs",
  "scripts": {
    "start": "node server.mjs",
    "dev:server": "nodemon server.mjs",
    "dev:client": "cd FRONTEND && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd FRONTEND && npm install && npm run build && cd .. && rm -rf dist && cp -r FRONTEND/dist dist"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "mongoose": "^9.2.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4"
  }
}
